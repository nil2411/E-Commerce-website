NODE_ENV=development
PORT=4000
MONGO_URL=mongodb://127.0.0.1:27017
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
# Comma-separated allowed frontend/admin origins. Wildcards are supported for Vercel previews.
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174,https://e-commerce-website-*.vercel.app
# Public storefront URL used in customer-facing emails.
PUBLIC_CLIENT_URL=http://localhost:5173
STORE_CURRENCY=inr
DELIVERY_CHARGE=10

CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_SECRET_KEY=
RAZORPAY_WEBHOOK_SECRET=

# Optional email delivery through the Resend HTTP API
RESEND_API_KEY=
EMAIL_FROM=Forever Store <orders@example.com>
